{
  "name": "bill-payment-api-testing",
  "version": "1.0.0",
  "description": "Bill Payment API test automation using Playwright, Jest, TypeScript with MongoDB and Kibana validation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:api": "jest tests/api --testPathPattern=api",
    "test:database": "jest tests/database --testPathPattern=database",
    "test:logs": "jest tests/logs --testPathPattern=logs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "ts-node",
    "clean": "rm -rf dist coverage reports"
  },
  "keywords": [
    "playwright",
    "jest",
    "typescript",
    "api-testing",
    "mongodb",
    "kibana",
    "test-automation"
  ],
  "author": "Chalita-bee",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.10.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "mongodb": "^6.3.0",
    "winston": "^3.11.0"
  }
}
